[user]
	email = ahyebear@gmail.com
	name = hzaybr
[alias]
  a = add
  cm = commit
  co = checkout
  l = log --date=short --decorate --pretty=format:"%C(yellow)%h%Creset\\ %ad%C(auto)%d%Creset\\ %C(bold)%C(black)%an%Creset\\ %s"
  s = status -s
  d = diff
  b = branch
[color]
  ui = true
[core]
  editor = vim
[push]
  default = simple
